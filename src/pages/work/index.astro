---
import Layout from "../../layouts/Layout.astro";
import CodingWrapped from "../../components/CodingStats/CodingWrapped.astro";
import flippImg from "../../assets/work/flipp.png";
import cohereImg from "../../assets/work/cohere.png";
import cfImg from "../../assets/work/cf.jpg";
import moofareImg from "../../assets/work/moonfare.jpeg";
import diginexImg from "../../assets/work/diginex.png";
import reloImage from "../../assets/work/relotalent.png";
import booksImg from "../../assets/work/books.png";
import moneyImg from "../../assets/work/money.png";
import coursesImg from "../../assets/work/courses.png";
import sideImg from "../../assets/work/side.png";
import spotifyImg from "../../assets/work/spotify-side.png";
import muscleImg from "../../assets/work/muscle.png";
import clockImg from "../../assets/work/wall-clock.png";
import profeshImg from "../../assets/tm-profesh.jpg";
import tanzimImg from "../../assets/tanzim.jpg";
import podacastImg from "../../assets/work/podcast.png";
import tribuneImg from "../../assets/work/tribune.png";
import { Image } from "astro:assets";

type TileType = "past" | "study" | "side" | "background";
interface Tile {
  company: string;
  title: string;
  desc: string;
  links: string[];
  linkTitles: string[];
  imageSrc: ImageMetadata;
  type: TileType;
  internal?: boolean;
  isImage?: boolean;
}

const tileHeaders: Record<TileType, string> = {
  background: "Overview",
  past: "Previously worked on",
  study: "Continuously pursuing knowledge",
  side: "Highlighted side projects",
};

const tileSectionIds: Record<TileType, string> = Object.fromEntries(
  Object.keys(tileHeaders).map((k) => [k as TileType, k]),
) as Record<TileType, string>;

const tiles: Tile[] = [
  {
    company: "Flipp",
    title: "Senior software engineer",
    desc: "Helped North Americans shop smarter with Flipp",
    links: ["https://flipp.com/home/"],
    linkTitles: ["Visit"],
    imageSrc: flippImg,
    type: "past",
    isImage: true,
  },
  {
    company: "Careerfoundry",
    title: "Web development mentor",
    desc: "Mentored the next generation of web developers",
    links: ["https://careerfoundry.com/"],
    linkTitles: ["Visit"],

    imageSrc: cfImg,
    type: "past",
    isImage: true,
  },
  {
    company: "Moonfare",
    title: "Software development engineer",
    desc: "Developed an investment platform for private equity",
    links: ["https://moonfare.com/"],
    linkTitles: ["Visit"],

    imageSrc: moofareImg,
    type: "past",
    isImage: true,
  },
  {
    company: "Diginex",
    title: "Full stack developer",
    desc: "Developed a cryptocurrency data aggregation and trading platform",
    links: ["https://www.diginex.com/"],
    linkTitles: ["Visit"],

    imageSrc: diginexImg,
    type: "past",
    isImage: true,
  },
  {
    company: "Relotalent",
    title: "Contract developer",
    desc: "Developed an expat compensation and tax calculation engine",
    links: ["https://www.relotalent.com/salary-calculator"],
    linkTitles: ["Visit"],

    imageSrc: reloImage,
    type: "past",
    isImage: true,
  },
  {
    company: "",
    title: "Books",
    desc: "My reading list of software engineering and adjacent books",
    links: ["https://github.com/users/mtanzim/projects/9"],
    linkTitles: ["Visit"],

    imageSrc: booksImg,
    type: "study",
  },
  {
    company: "",
    title: "Courses",
    desc: "My list of online courses past and present",
    links: ["https://github.com/users/mtanzim/projects/4"],
    linkTitles: ["Visit"],

    imageSrc: coursesImg,
    type: "study",
  },
  {
    company: "",
    title: "Side projects",
    desc: "Projects to explore new tools, techniques or for fun",
    links: ["https://github.com/users/mtanzim/projects/5"],
    linkTitles: ["Visit"],
    imageSrc: sideImg,
    type: "study",
  },
  {
    company: "",
    title: "Expense csv parser",
    desc: "Categorize, track and visualize expenses from bank CSV exports",
    imageSrc: moneyImg,
    links: ["https://github.com/mtanzim/cc-csv-parser"],
    linkTitles: ["Code"],

    type: "side",
  },
  {
    company: "",
    title: "Spotify listening habits",
    desc: "See what you've been listening to",
    imageSrc: spotifyImg,
    links: [
      "https://spotify.data.mtanzim.com/",
      "https://github.com/mtanzim/spotify-data",
    ],
    linkTitles: ["App", "Code"],

    type: "side",
  },
  {
    company: "",
    title: "Strong visualizer",
    desc: "Visualize progress from Strong app csvs",
    imageSrc: muscleImg,
    links: [
      "http://strong.data.mtanzim.com/",
      "https://github.com/mtanzim/vis-strong-go",
    ],
    linkTitles: ["App", "Code"],
    type: "side",
  },
  {
    company: "",
    title: "Wakatime dashboard",
    desc: "Persist Wakatime data and provide a visualization dashboard",
    imageSrc: clockImg,
    links: ["https://github.com/mtanzim/guac"],
    linkTitles: ["Code"],

    type: "side",
  },
  {
    company: "",
    title: "My story",
    desc: "Learn about my career switch to web development",
    imageSrc: tanzimImg,
    links: ["/work/story"],
    linkTitles: ["Visit"],
    type: "background",
    internal: true,
    isImage: true,
  },
  {
    company: "",
    title: "Resume",
    desc: "Get my detailed work history",
    imageSrc: profeshImg,
    links: ["/work/resume"],
    linkTitles: ["Visit"],
    type: "background",
    internal: true,
    isImage: true,
  },
  {
    company: "Cohere",
    title: "Member of technical staff",
    desc: "Currently, I'm helping expose the power of LLMs and RAG to developers and enterprise customers",
    imageSrc: cohereImg,
    links: ["https://cohere.com/"],
    linkTitles: ["Visit"],

    type: "background",
    internal: true,
    isImage: true,
  },
  {
    company: "",
    title: "Pycascades 2026 conference talk",
    desc: "Check out my talk on queues, tasks and distributed state management at Pycascades 2026 with co-speaker Chantelle",
    imageSrc: tribuneImg,
    links: [
      "https://www.youtube.com/live/CCv4y0B4M84?si=BI3Li4OHGY-Ff_6r&t=9605",
    ],
    linkTitles: ["Watch"],

    type: "background",
    isImage: true,
  },
  {
    company: "",
    title: "Podcast episode",
    desc: "Listen to a podcast episode where I discuss self studying software engineering, staying productive during long term travel, and the tech scene in Berlin",
    imageSrc: podacastImg,
    links: [
      "https://open.spotify.com/episode/5u3gXFNGomUkKimQHE9sgG?si=Op9ZjqG-RcuyWr9Uek2TvA",
    ],
    linkTitles: ["Listen"],

    type: "background",
    isImage: true,
  },
];
---

<Layout title="Work">
  <p class="text-base">
    <h1 id="overview" class="text-2xl my-6">Overview</h1>
    <p class="text-base mt-6">
      Learn more about my career journey, listen to a podcast episode, or check
      out my detailed resume:
    </p>
    <div class="my-6 h-1/2 max-w-full shadow-xl rounded-2xl bg-base-200 p-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-2">
        {
          tiles
            .filter((t) => t.type === "background")
            .map((tile) => (
              <div class="card hover:shadow-lg transition-shadow duration-300">
                <a
                  target={tile.internal ? "" : "_blank"}
                  href={tile.links[0] ?? "/"}
                >
                  <Image
                    class={`w-full h-48 ${tile.isImage ? "object-cover" : "object-contain"} rounded-t-2xl`}
                    src={tile.imageSrc}
                    alt={tile.title}
                  />
                </a>
                <div class="card-body items-center text-center p-4">
                  <h3 class="font-semibold text-base">{tile.title}</h3>
                  <p class="text-sm opacity-70">{tile.desc}</p>
                  <div class="card-actions justify-center mt-2" />
                </div>
              </div>
            ))
        }
      </div>
    </div>

    <h1 id="past" class="text-2xl my-6">Previously worked on</h1>
    <p class="text-base mt-6">
      I've had the privilege to work with amazing teams and companies throughout
      my career:
    </p>
    <div class="my-6 h-1/2 max-w-full shadow-xl rounded-2xl bg-base-200 p-8">
      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6"
      >
        {
          tiles
            .filter((t) => t.type === "past")
            .map((tile) => (
              <div class="card hover:shadow-lg transition-shadow duration-300">
                <a
                  target={tile.internal ? "" : "_blank"}
                  href={tile.links[0] ?? "/"}
                >
                  <Image
                    class={`w-full h-48 ${tile.isImage ? "object-cover" : "object-contain"} rounded-t-2xl`}
                    src={tile.imageSrc}
                    alt={tile.company || tile.title}
                  />
                </a>
                <div class="card-body items-center text-center p-4">
                  <h3 class="font-semibold text-base">{tile.title}</h3>
                  <p class="text-sm opacity-70">{tile.desc}</p>
                  <div class="card-actions justify-center mt-2" />
                </div>
              </div>
            ))
        }
      </div>
    </div>

    <h1 id="study" class="text-2xl my-6">Continuously pursuing knowledge</h1>
    <p class="text-base mt-6">
      I'm always learning and exploring new technologies and concepts through
      books, online courses, and hands on projects:
    </p>
    <div class="my-6 h-1/2 max-w-full shadow-xl rounded-2xl bg-base-200 p-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          tiles
            .filter((t) => t.type === "study")
            .map((tile) => (
              <div class="card hover:shadow-lg transition-shadow duration-300">
                <a
                  target={tile.internal ? "" : "_blank"}
                  href={tile.links[0] ?? "/"}
                >
                  <Image
                    class={`w-full h-48 ${tile.isImage ? "object-cover" : "object-contain"} rounded-t-2xl`}
                    src={tile.imageSrc}
                    alt={tile.title}
                  />
                </a>
                <div class="card-body items-center text-center p-4">
                  <h3 class="font-semibold text-base">{tile.title}</h3>
                  <p class="text-sm opacity-70">{tile.desc}</p>
                  <div class="card-actions justify-center mt-2" />
                </div>
              </div>
            ))
        }
      </div>
    </div>

    <h1 id="side" class="text-2xl my-6">Highlighted side projects</h1>
    <p class="text-base mt-6">
      I enjoy building side projects to explore new technologies and solve
      interesting problems. Here are a few highlights:
    </p>
    <div class="my-6 h-1/2 max-w-full shadow-xl rounded-2xl bg-base-200 p-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          tiles
            .filter((t) => t.type === "side")
            .map((tile) => (
              <div class="card hover:shadow-lg transition-shadow duration-300">
                <a
                  target={tile.internal ? "" : "_blank"}
                  href={tile.links[0] ?? "/"}
                >
                  <Image
                    class={`w-full h-48 ${tile.isImage ? "object-cover" : "object-contain"} rounded-t-2xl`}
                    src={tile.imageSrc}
                    alt={tile.title}
                  />
                </a>
                <div class="card-body items-center text-center p-4">
                  <h3 class="font-semibold text-base">{tile.title}</h3>
                  <p class="text-sm opacity-70">{tile.desc}</p>
                  <div class="card-actions justify-center mt-2" />
                </div>
              </div>
            ))
        }
      </div>
    </div>

    <h1 id="languages" class="text-2xl my-6">Languages in current use</h1>
    <p class="text-base mt-6">
      Following is a glimpse of the programming languages I've been using over
      the last few months based on data from Wakatime:
    </p>
    <div class="my-6">
      {
        import.meta.env.MODE === "development" ? (
          <div class="alert alert-info">
            <span>
              Guac will go here but lets not blow up my cheap serverless setup
            </span>
          </div>
        ) : (
          <CodingWrapped />
        )
      }
    </div>
  </p>
</Layout>
